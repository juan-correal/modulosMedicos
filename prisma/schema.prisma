// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum generos {
  M
  F
  otro
}
model roles {
  id_rol Int @id
  nombre_rol String @db.Varchar(50)
}

model usuarios {
  id_user Int @id @default(autoincrement())
  nombre_completo String @db.Varchar(100)
  username String @unique @db.Varchar(50)
  password String @db.Varchar(255)
  fk_rol Int
  fecha_registro DateTime @db.date
  roles roles @relation(fields: [fk_rol],references: [id_rol])  
}

model pacientes {
  id_paciente Int @id @default(autoincrement())
  nombre String @db.Varchar(100)
  edad Int
  genero generos
  eps String @db.Varchar(50)
  fecha_ingreso DateTime @db.date
}

model pqr_quejas {
  id_pqr Int @id @default(autoincrement())
  tipo String @db.Varchar(50)
  estado String @db.Varchar(20)
  id_paciente Int
  fecha DateTime @db.date
  paciente pacientes @relation(fields: [id_paciente],references: [id_paciente])
}

model citas_medicas {
  id_cita Int @id @default(autoincrement())
  especialidad String @db.Varchar(50)
  estado_cita String @db.Varchar(20)
  fecha DateTime @db.Date
  id_paciente Int 
  pacientes pacientes @relation(fields: [id_paciente],references: [id_paciente])
}

model medicamentos {
  id_med Int @id @default(autoincrement())
  nombre_med String @bd.Varchar(100)
  stock_actual Int 
  stock_minimo Int
  precio Decimal @db.Decimal(10,2)

}

model medicos {
id_medico Int @id @default(autoincrement())
nombre_medico String @db.Varchar(100)
especialidad String @db.Varchar(50)
turno String @db.Varchar(20)

}

model facturas {
  id_factura Int @id @default(autoincrement())
  metodo_pago String @db.Varchar(50)
  monto Decimal @db.Decimal(10,2)
  fecha_pago DateTime @db.Date
  
}

model laboratio {
  id_lab Int @id @default(autoincrement())
  tipo_examen String @db.Varchar(50)
  resultado String @db.Varchar(20)
  fecha DateTime @db.Date

}

model camas_hosp {
  id_cama Int @id @default(autoincrement())
  piso Int
  estado_cama String @db.Varchar 

}

model proveedores {
  id_prov Int @id @default(autoincrement())
  nombre_empresa String @db.Varchar(100)
  monto_deuda Decimal @db.Decimal(10,2)
  calificacion Int
}

model ambulancias {
  id_amb Int @id @default(autoincrement())
  placa String @db.Varchar(10)
  km_recorrido Int 
  estado_mecanico String @db.Varchar(20)

}

model insumos_aseo {
  id_aseo Int @id @default(autoincrement())
  articulo String @db.Varchar(50)
  cantidad Int
  area_uso String @db.Varchar(50)

}

model historias_clin {
  id_hist Int @id @default(autoincrement())
  enfermedad String @db.Varchar(100)
  alergias String @db.Varchar(100)
  id_paciente Int
  paciente pacientes @relation(fields: [id_paciente],references: [id_paciente])

}

model recetas_med {
  id_receta Int @id @default(autoincrement())
  id_medico Int
  cantidad_med Int
  fecha_receta DateTime @db.Date
  medico medicos @relation(fields: [id_medico],references: [id_medico])

}

model nomina_pers {
  id_nom Int @id @default(autoincrement())
  cargo String @db.Varchar(50)
  sueldo Decimal @db.Decimal(10,2)
  faltas Int

}

model emergencias {
  id_em Int @id @default(autoincrement())
  triaje Int
  tiempo_espera_min Int
  fecha DateTime @db.Date

}

model equipos_med {
  id_equipo Int @id @default(autoincrement())
  nombre_equipo String @db.Varchar(100)
  estado_uso String @db.Varchar(20)
  dias_para_mantenimiento Int 
}